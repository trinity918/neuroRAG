# Copy to .env and fill in as needed. All values are OPTIONAL — NeuroGraphRAG
# runs fully offline without any of these. They only enable the LLM-backed
# answer synthesis and (optionally) faithful RAGAS scoring.

# LLM provider for answer synthesis: "none" (extractive, default), "anthropic", "openai"
NGR_LLM_PROVIDER=none

# Only read when NGR_LLM_PROVIDER != none
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Dense embedding backend: "concept-hash" (default, no downloads) or "sentence-transformers"
NGR_EMBEDDING_BACKEND=concept-hash
NGR_ST_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Path to a trained LoRA adapter to merge into the ST encoder (optional)
NGR_LORA_ADAPTER=
